{
  "name": "nix-garden",
  "version": "1.0.0",
  "description": "NiX Garden — 和風 Voxel 種田家園 Three.js Game",
  "main": "index.html",
  "scripts": {
    "dev": "npx live-server --port=3000 --open=index.html",
    "cap:init": "npx cap init \"NiX Garden\" \"com.nixgarden.app\" --web-dir=.",
